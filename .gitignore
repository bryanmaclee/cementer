# Go binary (incl. cross-compiled Pi builds: cementer-arm64, cementer-arm64-new, ...)
/cementer
/cementer-arm64*

# Runtime data (durable store + raw logs) — never commit
/data/
*.db
*.db-wal
*.db-shm
raw-*.log

# Node / client build
/web/node_modules/
# Embedded at build time via go:embed; rebuilt by `npm run build` (see Makefile)
/web/dist/

# Editor / OS
*.swp
.DS_Store

# Multi-operator coordination worktree (the unprotected 'coord' branch lives here; run `make coord`)
/.coord/
